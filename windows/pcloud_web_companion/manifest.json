{
  "manifest_version": 3,
  "name": "pCloud Download → Loop Segments",
  "version": "1.7.3",
  "description": "Cancels pCloud downloads/CDN tabs ASAP; multi-select archive → phone export_queue.json FIFO; single file → export_from_folder.json.",
  "permissions": [
    "downloads",
    "offscreen",
    "clipboardWrite",
    "storage",
    "notifications",
    "tabs",
    "windows",
    "scripting",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "http://*:8765/*",
    "http://127.0.0.1:18765/*",
    "http://*/*",
    "https://*.pcloud.com/*",
    "https://pcloud.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://my.pcloud.com/*",
        "https://e.pcloud.com/*",
        "https://*.pcloud.com/*"
      ],
      "js": ["pcloud_fileid_hook_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://my.pcloud.com/*",
        "https://e.pcloud.com/*",
        "https://*.pcloud.com/*"
      ],
      "js": ["pcloud_folder_tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "REST logs",
    "default_popup": "logs.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png"
  }
}
