{
  "manifest_version": 3,
  "name": "pCloud Download → Loop Segments",
  "version": "1.6.5",
  "description": "Cancels pCloud downloads/CDN tabs ASAP, derives API host from CDN, POSTs export_from_folder.json, opens /browse.",
  "permissions": [
    "downloads",
    "offscreen",
    "clipboardWrite",
    "storage",
    "notifications",
    "tabs",
    "windows",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "http://*:8765/*",
    "http://127.0.0.1:18765/*",
    "http://*/*",
    "https://*.pcloud.com/*",
    "https://pcloud.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://my.pcloud.com/*",
        "https://e.pcloud.com/*",
        "https://*.pcloud.com/*"
      ],
      "js": ["pcloud_folder_tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "REST logs",
    "default_popup": "logs.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png"
  }
}
